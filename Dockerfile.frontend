# 智能财务分析平台 — React 前端 (Vite)
FROM node:22-alpine

WORKDIR /app

# 依赖
COPY web/package.json web/package-lock.json ./
RUN npm ci

# 源码
COPY web/ ./

# 构建
RUN npm run build

# Nginx 托管静态文件
FROM nginx:alpine
COPY --from=0 /app/dist /usr/share/nginx/html
COPY web/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
