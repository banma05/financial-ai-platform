# 智能财务分析平台 — FastAPI 后端
FROM python:3.12-slim

WORKDIR /app

# 系统依赖（PyMuPDF + matplotlib）
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1-mesa-glx libglib2.0-0 libsm6 libxext6 libxrender-dev \
    && rm -rf /var/lib/apt/lists/*

# Python 依赖
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir redis

# 项目代码
COPY backend/ ./backend/
COPY data/ ./data/
COPY evaluation/ ./evaluation/
COPY scripts/ ./scripts/

# 环境变量
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/backend
ENV DEEPSEEK_API_KEY=""
ENV CHROMA_PERSIST_DIR=/app/data/chroma_db
ENV LOCAL_MODEL_PATH=/app/data/models/BAAI/bge-base-zh-v1___5
ENV CHART_OUTPUT_DIR=/app/data/charts
ENV UPLOAD_DIR=/app/data/documents
ENV HF_HOME=/app/data/models

# GPU 支持（可选，无 GPU 时自动回退 CPU）
ENV TOKENIZERS_PARALLELISM=false

EXPOSE 8001

CMD ["python", "-m", "uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8001"]
